# ============================================================
# Career AI Assistant - environment configuration
# ============================================================
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
# Then open `.env` and add your Anthropic API key.
# ============================================================

# ---- Anthropic Claude API ----
# Get a key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-replace-me

# Claude model to use. Recommended:
#   claude-opus-4-7         -> highest quality (slower, costlier)
#   claude-sonnet-4-6       -> balanced (recommended default)
#   claude-haiku-4-5-20251001 -> fastest, cheapest
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.3

# ---- Embeddings ----
# A small, fast, CPU-friendly model. Downloaded automatically on first run.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ---- Vector store (ChromaDB) ----
CHROMA_PERSIST_DIR=./embeddings
CHROMA_COLLECTION=career_profile

# ---- Chunking ----
CHUNK_SIZE=900
CHUNK_OVERLAP=120

# ---- Retrieval ----
RAG_TOP_K=6

# ---- Paths ----
DATA_DIR=./data
PROMPTS_DIR=./prompts
DB_PATH=./career_assistant.db

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FILE=./career_assistant.log
